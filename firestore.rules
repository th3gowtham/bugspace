rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // ============================================
    // HELPER FUNCTIONS
    // ============================================
    
    // Check if user is authenticated
    function isAuthenticated() {
      return request.auth != null;
    }
    
    // Check if user is accessing their own document
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }
    
    // Check if user is an admin (document exists in admins collection)
    function isAdmin() {
      return isAuthenticated() && 
        exists(/databases/$(database)/documents/admins/$(request.auth.uid));
    }
    
    // Check if user is an employer (document exists in employers collection)
    function isEmployer() {
      return isAuthenticated() && 
        exists(/databases/$(database)/documents/employers/$(request.auth.uid));
    }
    
    // Safe fields that users can update on their own profile
    function isSafeUserUpdate() {
      return request.resource.data.diff(resource.data).affectedKeys()
        .hasOnly(['fullName', 'updatedAt', 'seenAnnouncements', 'bookmarkedBugs', 'lastActiveAt']);
    }

    // Fields that the referral system may update on any user document.
    // NOTE: For production, move referral writes to a Cloud Function so these
    // writes are fully server-authorised. Client-side referral updates are
    // intentionally restricted to these fields only.
    function isReferralUpdate() {
      return request.resource.data.diff(resource.data).affectedKeys()
        .hasOnly([
          'referralCode',
          'referralCount',
          'referredBy',
          'premiumUntil',
          'premiumSource',
          'premiumGrantedAt',
          'referralRewardApplied',
          'referralTierGranted',
          'referredByPromoCode',
          'referralSource',
          'signupIP',
          'deviceFingerprint',
          'premiumStatus',
          'premiumPurchaseDate'
        ]);
    }

    // ============================================
    // USERS COLLECTION - Auto-created on signup
    // ============================================
    match /users/{userId} {
      // Users can read their own document
      // Admins can read any user document
      allow read: if isOwner(userId) || isAdmin();
      
      // Users can create their own document on signup
      // Must match authenticated user's uid and have required fields
      allow create: if isOwner(userId) 
        && request.resource.data.uid == request.auth.uid
        && 'email' in request.resource.data
        && 'fullName' in request.resource.data;
      
      // Users can update only safe fields on their own document.
      // Any authenticated user can perform a pure referral-field update
      // (incrementing referralCount, setting premiumUntil, etc.).
      allow update: if (isOwner(userId) && isSafeUserUpdate())
        || (isAuthenticated() && isReferralUpdate());
      
      // No deletion from client
      allow delete: if false;
    }
    
    // ============================================
    // ADMINS COLLECTION - Manual only yesty
    // ============================================
    match /admins/{adminId} {
      // Authenticated users can read admin collection (for role detection by email)
      allow read: if isAuthenticated();
      
      // NO client-side writes allowed
      // Admins are added manually via Firebase Console or Admin SDK
      allow create, update, delete: if false;
    }
    
    // ============================================
    // EMPLOYERS COLLECTION - Manual only
    // ============================================
    match /employers/{employerId} {
      // Authenticated users can read employer collection (for role detection by email)
      allow read: if isAuthenticated();
      
      // NO client-side writes allowed
      // Employers are added manually via Firebase Console or Admin SDK
      allow create, update, delete: if false;
    }
    
    // ============================================
    // PREMIUM USERS COLLECTION
    // ============================================
    match /premiumUsers/{userId} {
      // Users can read their own premium document to check access
      allow read: if isOwner(userId) || isAdmin();

      // Only admins can create, update, or delete premium access records
      allow create, update, delete: if isAdmin();
    }

    // ============================================
    // PROGRAMS COLLECTION - For bug bounty programs
    // ============================================
    match /programs/{programId} {
      // Any authenticated user can read programs
      allow read: if isAuthenticated();
      
      // Authenticated user can create a program; employer check is enforced
      // on the frontend (employers stored by email, not uid, so exists() cannot
      // be used here). createdBy must equal the caller's UID.
      allow create: if isAuthenticated()
        && request.resource.data.createdBy == request.auth.uid;
      
      // Only the original creator can update their own program
      allow update: if isAuthenticated()
        && resource.data.createdBy == request.auth.uid;
      
      // Only the original creator can delete their own program
      allow delete: if isAuthenticated()
        && resource.data.createdBy == request.auth.uid;
    }
    
    // ============================================
    // PREMIUM USERS COLLECTION
    // ============================================
    match /premiumUsers/{userId} {
      // Users can read their own premium document to check access
      allow read: if isOwner(userId) || isAdmin();

      // Only admins can create, update, or delete premium access records
      allow create, update, delete: if isAdmin();
    }

    // ============================================
    // BOOKMARKS COLLECTION
    // ============================================
    match /bookmarks/{bookmarkId} {
      // Users can only read their own bookmarks
      allow read: if isAuthenticated()
        && resource.data.userId == request.auth.uid;
      
      // Users can create bookmarks for themselves only
      allow create: if isAuthenticated()
        && request.resource.data.userId == request.auth.uid;
      
      // Users can delete only their own bookmarks
      allow delete: if isAuthenticated()
        && resource.data.userId == request.auth.uid;
      
      // No client-side updates
      allow update: if false;
    }

    // ============================================
    // REPORTS COLLECTION - Bug reports
    // ============================================
    match /reports/{reportId} {
      // Users can read their own reports
      // Employers can read reports for their programs
      // Admins can read all reports
      allow read: if isOwner(resource.data.researcherId) 
        || (isEmployer() && resource.data.programOwnerId == request.auth.uid)
        || isAdmin();
      
      // Authenticated users can create reports
      allow create: if isAuthenticated() 
        && request.resource.data.researcherId == request.auth.uid;
      
      // Researchers can update their own reports (limited fields)
      // Employers can update reports for their programs (status only)
      // Admins can update any report
      allow update: if isOwner(resource.data.researcherId)
        || (isEmployer() && resource.data.programOwnerId == request.auth.uid)
        || isAdmin();
      
      // Only admin can delete reports
      allow delete: if isAdmin();
    }
    
    // ============================================
    // BOUNTIES COLLECTION - Per-user reward tracking
    // Structure: bounties/{uid}/entries/{entryId}
    // ============================================
    match /bounties/{uid}/entries/{entryId} {
      // Only the owner can read their own entries
      allow read: if isOwner(uid);

      // Owner can create entries under their own uid
      allow create: if isOwner(uid)
        && request.resource.data.uid == request.auth.uid;

      // Owner can update their own entries
      allow update: if isOwner(uid)
        && resource.data.uid == request.auth.uid;

      // Owner can delete their own entries
      allow delete: if isOwner(uid)
        && resource.data.uid == request.auth.uid;
    }

    // ============================================
    // NOTES_FOLDERS - Research note folders
    // ============================================
    match /notes_folders/{folderId} {
      allow read, write: if request.auth != null;
    }

    // ============================================
    // NOTES_PAGES - Research note pages
    // ============================================
    match /notes_pages/{pageId} {
      allow read, write: if request.auth != null;
    }

    // ============================================
    // NOTES_FOLDERS - Research note folders
    // ============================================
    match /notes_folders/{folderId} {
      allow read, write: if request.auth != null;
    }

    // ============================================
    // NOTES_PAGES - Research note pages
    // ============================================
    match /notes_pages/{pageId} {
      allow read, write: if request.auth != null;
    }

    // ============================================
    // NOTES_SHARES - Note sharing invites
    // ============================================
    match /notes_shares/{shareId} {
      // Owner can read/write their own shares; target can read & update status
      allow read:   if request.auth != null;
      allow create: if request.auth != null;
      allow update: if request.auth != null;
      allow delete: if request.auth != null;
    }

    // ============================================
    // REFERRALS COLLECTION - Referral records
    // ============================================
    match /referrals/{referralId} {
      // Only the referrer or referred user can read the record. Admins can read all.
      allow read: if isAdmin()
        || (isAuthenticated() && (
          resource.data.referrerUid == request.auth.uid
          || resource.data.referredUid == request.auth.uid
        ));

      // Any authenticated user can create a referral record during signup.
      // The service code enforces anti-abuse checks (no self-referral, no duplicate).
      allow create: if isAuthenticated()
        && request.resource.data.referredUid == request.auth.uid;

      // No client-side updates or deletes once created
      allow update, delete: if false;
    }

    // ============================================
    // PROMOTERS COLLECTION
    // NOTE: Promoter login currently uses custom client-side auth and requires
    // unauthenticated reads. Move this validation to a trusted backend for
    // production deployments.
    // ============================================
    match /promoters/{promoterId} {
      // Referral processing runs after user signup while authenticated,
      // so promoter reads must allow authenticated users as well.
      allow read: if isAdmin() || isAuthenticated() || request.auth == null;
      allow create, update, delete: if isAdmin();
    }

    // ============================================
    // PROMOTER REFERRALS COLLECTION
    // ============================================
    match /promoterReferrals/{referralId} {
      allow read: if isAdmin() || request.auth == null;

      allow create: if isAuthenticated()
        && request.resource.data.userId == request.auth.uid;

      allow update: if isAdmin() || isAuthenticated();

      allow delete: if false;
    }

    // ============================================
    // ANALYTICS COLLECTION - Page visit tracking
    // Fields: userId, page, timestamp
    // ============================================
    match /analytics/{visitId} {
      // Only admins can read analytics data
      allow read: if isAdmin();

      // Authenticated users can log their own page visits
      allow create: if isAuthenticated()
        && request.resource.data.userId == request.auth.uid
        && 'page' in request.resource.data
        && 'timestamp' in request.resource.data;

      // No client-side updates or deletes
      allow update, delete: if false;
    }

    // ============================================    // ANNOUNCEMENTS COLLECTION
    // ============================================
    match /announcements/{announcementId} {
      // Any authenticated user can read announcements
      allow read: if isAuthenticated();

      // Only admins can create, update, or delete announcements
      allow create, update, delete: if isAdmin();
    }

    // ============================================
    // USER ANNOUNCEMENTS COLLECTION
    // Tracks which announcements each user has seen.
    // Fields: userId, announcementId, seenAt
    // ============================================
    match /userAnnouncements/{recordId} {
      // Users can only read their own seen records
      allow read: if isAuthenticated()
        && resource.data.userId == request.auth.uid;

      // Users can create a seen record only for themselves
      allow create: if isAuthenticated()
        && request.resource.data.userId == request.auth.uid
        && request.resource.data.keys().hasAll(['userId', 'announcementId', 'seenAt']);

      // No client-side updates or deletes
      allow update, delete: if false;
    }

    // ============================================    // ============================================
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
